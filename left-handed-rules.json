{
    "description": "Half-qwerty keyboard emulation for left-handed users",
    "manipulators": [
        // spacebar
        {
            "conditions": [
                {
                    "name": "space_waiting_second_tap",
                    "type": "variable_if",
                    "value": 1
                }
            ],
            "from": {
                "key_code": "spacebar",
                "modifiers": { "optional": ["any"] }
            },
            "to": [
                { "key_code": "spacebar" },
                {
                    "set_variable": {
                        "name": "space_waiting_second_tap",
                        "value": 0
                    }
                }
            ],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "spacebar",
                "modifiers": { "optional": ["any"] }
            },
            "to": [
                {
                    "set_variable": {
                        "name": "right_hand",
                        "value": 1
                    }
                }
            ],
            "to_after_key_up": [
                {
                    "set_variable": {
                        "name": "right_hand",
                        "value": 0
                    }
                }
            ],
            "to_if_alone": [
                {
                    "set_variable": {
                        "name": "space_waiting_second_tap",
                        "value": 1
                    }
                }
            ],
            "to_delayed_action": {
                "to_if_invoked": [
                    {
                        "set_variable": {
                            "name": "space_waiting_second_tap",
                            "value": 0
                        }
                    }
                ],
                "to_if_canceled": []
            },
            "type": "basic"
        },
